---
import Layout from '../layouts/Layout.astro';
import ClubCalendar from '../components/ui/ClubCalendar';
import { ICS_URL, parseIcs } from '../lib/ics-parser';

let buildTimeEvents: import('../lib/ics-parser').ParsedEvent[] = [];

try {
  const res = await fetch(ICS_URL);
  if (res.ok) {
    const text = await res.text();
    if (text.includes('BEGIN:VCALENDAR')) {
      buildTimeEvents = parseIcs(text);
    }
  }
} catch (e) {
  console.warn('[Calendar] Build-time fetch failed:', e);
}
---

<Layout title="Calendar">
    <section class="page-header">
        <div class="container">
            <h1 class="page-title fade-up">Calendar</h1>
            <p class="fade-up delay-1">Stay up to date with events at the Dowagiac Conservation Club.</p>
        </div>
    </section>

    <section class="content-section bg-light-alt">
        <div class="container grid-container">
            <div class="events-col slide-up delay-2">
                <ClubCalendar client:load initialEvents={buildTimeEvents} />
            </div>

            <div class="info-col slide-up delay-3">
                <div class="text-block h-full">
                    <h3>Important Range Information</h3>
                    <p class="highlight-box"><strong>RANGE MOWING AND MAINTENANCE OCCUR AS WEATHER AND VOLUNTEER TIME ALLOW AND WON'T APPEAR ON CALENDAR. TALK TO THE VOLUNTEER TO SEE HOW SOON YOU CAN SHOOT.</strong></p>
                    <p>Ranges and Lake Access are for use of Members only, or as approved by the Board of Directors. Be ready to show your current membership card if asked. Unless otherwise noted in calendar, ranges are open Monday thru Sunday 9 a.m. to sunset. Read RANGE RULES before using ranges.</p>
                    
                    <h3 class="mt-5 text-xl">Hunter Safety Classes</h3>
                    <p>Dates have not been set for 2026.</p>
                    <p class="text-sm">When future dates are set Club Members with email addresses on file will be notified of the dates and how to register. To search for classes in other locations go to: <a href="https://www.michigan.gov/dnr/things-to-do/hunting/education" target="_blank" rel="noopener noreferrer" class="text-link">Michigan DNR Hunter Education</a>.</p>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style is:global>
    .page-header {
        padding: 140px 0 60px;
        background-color: var(--clr-forest);
        color: var(--clr-white);
        text-align: center;
        background-image: linear-gradient(rgba(28, 51, 39, 0.85), rgba(28, 51, 39, 0.85)), url('/hero_bg.png');
        background-size: cover;
        background-position: center;
    }
    
    .page-title {
        color: var(--clr-gold);
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }
    
    .content-section {
        padding: 5rem 0;
    }
    
    .info-col {
        display: flex;
        flex-direction: column;
    }
    
    .text-block {
        background: var(--clr-white);
        padding: 2.5rem;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    
    .text-block h3 {
        color: var(--clr-forest);
        margin-bottom: 1rem;
    }
    
    .text-block p {
        margin-bottom: 1.5rem;
        color: var(--clr-dark);
        line-height: 1.7;
    }
    
    .highlight-box {
        background-color: rgba(198, 168, 124, 0.1);
        border-left: 4px solid var(--clr-gold);
        padding: 1rem 1.25rem;
        border-radius: 0 8px 8px 0;
        color: var(--clr-forest);
    }
    
    .bg-light-alt { background-color: #eef1ec; }
    .mt-5 { margin-top: 3rem; }
    .text-xl { font-size: 1.5rem; }
    .text-sm { font-size: 0.9rem; }
    .h-full { height: 100%; }
    
    @media (max-width: 992px) {
        .grid-container {
            grid-template-columns: 1fr;
        }
    }
</style>